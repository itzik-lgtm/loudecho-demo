# LoudEcho Demo — environment variable reference
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; never commit real API keys.

# ── Scene 1: Image analysis (Anthropic Claude) ────────────────────────────────
# Required for the seed-ad analysis flow in Scene 1.
# Get a key at: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# ── Scene 2: Variant refinement (Nano Banana 2 / Gemini) ─────────────────────
# Set GEMINI_API_KEY to enable real image generation via Google Gemini.
# Get a key at: https://aistudio.google.com/apikey
#
# The key is read by the Vite dev-server middleware (server-side only via
# process.env) and is never bundled into the browser build.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Set to "true" to bypass the Gemini API and use the local development mock
# instead. The mock picks an alternative static image from the same IAB axis
# pool with a simulated 2–3.5 s delay — useful when no Gemini key is available.
# Remove this line (or set to "false") to use the real API.
VITE_USE_MOCK_NANO_BANANA=true

# ── Demo mode (default: ON) ──────────────────────────────────────────────────
# When on, all live API calls (Claude analysis, Gemini generation) return
# scripted responses near-instantly — zero stall risk while presenting.
# Set to "false" to enable real API calls (requires the keys above).
# VITE_DEMO_MODE=false
